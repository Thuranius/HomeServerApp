<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= room.name %> - Party Room</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="page-shell">
      <main class="card room-card">
        <section class="hero">
          <span class="eyebrow">Room Ready</span>
          <h1><%= room.name %></h1>
          <p>Room ID: <strong><%= room.id %></strong></p>
        </section>

        <section class="info-block">
          <p>Share this link with your friends:</p>
          <pre class="room-link"><%= room.url %></pre>
        </section>

        <section id="lobbyPanel" class="game-panel">
          <div class="panel-title">
            <h2>Party Lobby</h2>
            <p>Pick your class, then wait for the host to start the adventure.</p>
          </div>

          <div id="classOptions" class="class-grid"></div>

          <div class="panel-body">
            <h3>Party roster</h3>
            <ul id="playerList" class="user-list"></ul>
            <button id="startGameButton" class="primary-button hidden">Start adventure</button>
            <button id="openShopButton" class="secondary-button">Open shop</button>
            <div id="lobbyNotice" class="panel-note"></div>
          </div>
        </section>

        <section id="votePanel" class="game-panel hidden">
          <div class="panel-title">
            <h2>Choose your path</h2>
            <p>Vote for the next route. Host breaks ties.</p>
          </div>

          <div id="routeOptions" class="route-grid"></div>
          <div id="voteStatus" class="panel-note"></div>
        </section>

        <section id="restPanel" class="game-panel hidden">
          <div class="panel-title">
            <h2>Rest & prepare</h2>
            <p>Take a short break between stages. Choose a branch when available.</p>
          </div>

          <div id="restStatus" class="panel-note"></div>
          <div id="restRouteOptions" class="route-grid"></div>
          <button id="continueButton" class="primary-button hidden">Continue adventure</button>

          <div class="panel-body">
            <h3>Inventory</h3>
            <ul id="restInventoryList" class="inventory-list"></ul>
          </div>

          <div class="panel-body">
            <h3>Battle log</h3>
            <ul id="restBattleLog" class="battle-log"></ul>
          </div>
        </section>

        <section id="resultPanel" class="game-panel hidden">
          <div class="panel-title">
            <h2 id="resultTitle">Run complete</h2>
            <p id="resultSummary">The adventure has concluded.</p>
          </div>
          <div class="panel-body">
            <h3>Battle log</h3>
            <ul id="resultLog" class="battle-log"></ul>
          </div>
        </section>

        <section id="shopPanel" class="game-panel hidden">
          <div class="panel-title">
            <h2>Adventurer's Shop</h2>
            <p>Spend currency on consumables, equipment, and permanent perks.</p>
          </div>
          <div id="shopStatus" class="panel-note"></div>
          <div id="shopOffers" class="route-grid"></div>
          <button id="closeShopButton" class="secondary-button">Leave shop</button>
        </section>

        <section id="combatPanel" class="game-panel hidden">
          <div class="panel-title">
            <h2>Adventure in progress</h2>
            <p>Use your actions to defeat the enemy.</p>
          </div>

          <div class="combat-top-row">
            <div id="enemyCard" class="enemy-card combat-card"></div>
            <div id="playerStatusPanel" class="combat-card player-status-panel"></div>
          </div>

          <div class="combat-main-row">
            <div id="combatDetails" class="combat-card combat-details-panel"></div>
            <div class="combat-actions-panel">
              <div class="panel-title">
                <h3>Abilities</h3>
              </div>
              <div class="action-grid" id="actionGrid"></div>
              <div id="actionStatus" class="panel-note"></div>
            </div>
          </div>

          <div class="panel-body">
            <h3>Inventory</h3>
            <ul id="inventoryList" class="inventory-list"></ul>
          </div>

          <div class="panel-body">
            <h3>Battle log</h3>
            <ul id="battleLog" class="battle-log"></ul>
          </div>
        </section>

        <a class="secondary-button" href="/">Back to home</a>
      </main>
    </div>

    <div class="name-prompt hidden" id="namePrompt">
      <div class="name-prompt-card">
        <h2>Enter your name</h2>
        <p>To join this room, please tell us your name.</p>
        <form id="namePromptForm">
          <label for="promptName">Name</label>
          <input id="promptName" name="promptName" type="text" placeholder="Enter your name" autocomplete="name" />
          <button type="submit" class="primary-button">Join room</button>
        </form>
      </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
      window.ROOM_ID = '<%= room.id %>';
    </script>
    <script src="/script.js"></script>
  </body>
</html>
